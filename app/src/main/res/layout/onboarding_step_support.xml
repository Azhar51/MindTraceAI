<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤝  Support around you" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="How supported do you feel by people around you?" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Social support" />
                    <TextView android:id="@+id/tv_support_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView android:id="@+id/tv_support_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Some support — a few people you can talk to" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_social_support" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />

                <!-- NEW: Social Quality Baseline -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Quality of connections" />
                    <TextView android:id="@+id/tv_social_quality_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView android:id="@+id/tv_social_quality_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Mixed — some connections feel meaningful" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_social_quality" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- NEW: Readiness to Change -->
        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥  Readiness to change" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="How ready are you to make real changes in your digital habits?" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Readiness level" />
                    <TextView android:id="@+id/tv_readiness_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" />
                </LinearLayout>
                <TextView android:id="@+id/tv_readiness_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Contemplation — thinking about change" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_readiness" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="10" android:stepSize="1" android:value="5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Toggle.Card" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:padding="18dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🫶  Show support tools" />
                    <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Enable calmer prompts and grounding tools when needed." />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_support_needed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Toggle.Card" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:padding="18dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛟  Safety resources" />
                    <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Keeps help-oriented resources easier to reach if patterns suggest it." />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_safety_support"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:checked="true" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
