<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:background="@drawable/bg_app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Guided flow (§2E1.7) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How are you feeling?"
                android:textColor="#E8ECF4"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Give MindTrace one fresh signal so your guidance stays current."
            android:textColor="#8896B0"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mood &amp; Stress"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/mood_question"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <!-- Mood: Tappable emoji cards (§2E1.7) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Hidden RadioGroup for data binding (keeps Java references working) -->
                    <RadioGroup
                        android:id="@+id/rg_mood"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone">
                        <RadioButton android:id="@+id/rb_happy" android:layout_width="0dp" android:layout_height="0dp" android:text="Happy" />
                        <RadioButton android:id="@+id/rb_neutral" android:layout_width="0dp" android:layout_height="0dp" android:text="Neutral" android:checked="true" />
                        <RadioButton android:id="@+id/rb_sad" android:layout_width="0dp" android:layout_height="0dp" android:text="Sad" />
                        <RadioButton android:id="@+id/rb_anxious" android:layout_width="0dp" android:layout_height="0dp" android:text="Anxious" />
                    </RadioGroup>

                    <!-- Emoji card: Happy -->
                    <LinearLayout
                        android:id="@+id/emoji_happy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_mood_emoji_unselected"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😊"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Happy"
                            android:textColor="#8896B0"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Emoji card: Neutral -->
                    <LinearLayout
                        android:id="@+id/emoji_neutral"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_mood_emoji_selected"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😐"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Neutral"
                            android:textColor="#7C8FFF"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Emoji card: Sad -->
                    <LinearLayout
                        android:id="@+id/emoji_sad"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_mood_emoji_unselected"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😢"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sad"
                            android:textColor="#8896B0"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Emoji card: Anxious -->
                    <LinearLayout
                        android:id="@+id/emoji_anxious"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_mood_emoji_unselected"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😰"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anxious"
                            android:textColor="#8896B0"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Stress Level (1-5)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_stress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Loneliness Level (1-5)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_loneliness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Motivation Level (1-5)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_motivation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Functioning"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Work Pressure"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <RadioGroup
                    android:id="@+id/rg_work_pressure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb_work_low"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Low"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_work_medium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Medium"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_work_high"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="High"
                        android:textColor="@color/text_main" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Hours of sleep last night"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/et_sleep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 7.5"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="How was your focus today?"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <RadioGroup
                    android:id="@+id/rg_focus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb_focus_low"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Low"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_focus_medium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Medium"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_focus_high"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="High"
                        android:textColor="@color/text_main" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Did you feel distracted?"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <RadioGroup
                    android:id="@+id/rg_distracted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb_distracted_yes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Yes"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_distracted_no"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="No"
                        android:textColor="@color/text_main" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Urge to mindlessly scroll (1-5)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_urge_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="3" />

                <TextView
                    android:id="@+id/tv_urge_scroll_descriptor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Moderate — noticeable urges"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="What was your biggest distraction?"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/et_biggest_distraction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. TikTok, News, Work emails..."
                    android:inputType="text"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Energy level"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <RadioGroup
                    android:id="@+id/rg_energy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb_energy_low"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Low"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_energy_medium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Medium"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_energy_high"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="High"
                        android:textColor="@color/text_main" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Support &amp; Direction"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_social_support"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:checked="true"
                    android:text="I feel socially supported right now"
                    android:textColor="@color/text_main" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_goal_clarity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:checked="true"
                    android:text="I feel clear about my next goal"
                    android:textColor="@color/text_main" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_felt_crying"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:checked="false"
                    android:text="I felt like crying today"
                    android:textColor="@color/text_main" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_wanted_withdraw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:checked="false"
                    android:text="I wanted to withdraw from people"
                    android:textColor="@color/text_main" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Gratitude & Reflection Card ── -->

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gratitude &amp; Self-Perception"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_gratitude_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="What are you grateful for today?"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_gratitude"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_surface"
                    android:gravity="top|start"
                    android:hint="e.g. My morning coffee, a kind word from a friend..."
                    android:inputType="textMultiLine"
                    android:lines="3"
                    android:minLines="2"
                    android:padding="12dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Self-Worth (1 = very low, 5 = confident)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_self_worth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Sense of Purpose (1 = none, 5 = strong)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_purpose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Hope Level (1 = hopeless, 5 = optimistic)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_hope"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Adaptive Support Card (hidden by default) ── -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_adaptive_support"
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💙 We noticed you've been feeling down"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_adaptive_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="You've reported feeling sad for multiple days. Would you like MindTrace to connect you with support resources?"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_request_support"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:checked="false"
                    android:text="Yes, I'd like support"
                    android:textColor="@color/text_main" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Current State & Body Card (for AI Coach) ── -->

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current State &amp; Body"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Anxiety Level (1-5)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_anxiety"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="2" />

                <TextView
                    android:id="@+id/tv_anxiety_descriptor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Mild — some worry"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Sleep Quality (1-5)"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />

                <SeekBar
                    android:id="@+id/sb_sleep_quality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:min="1"
                    android:progress="3" />

                <TextView
                    android:id="@+id/tv_sleep_quality_descriptor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Decent — woke up okay"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_exercised_today"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:checked="false"
                    android:text="I exercised or moved my body today"
                    android:textColor="@color/text_main" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="What\u2019s weighing on your mind right now?"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Your coach will read this and give you personalized advice."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_current_concern"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_surface"
                    android:gravity="top|start"
                    android:hint="e.g. I can\u2019t stop scrolling at night, I feel stuck in my career..."
                    android:inputType="textMultiLine"
                    android:lines="4"
                    android:minLines="3"
                    android:padding="12dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:text="⚡ Save &amp; Analyze"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:cornerRadius="14dp"
            app:backgroundTint="#7C8FFF" />

    </LinearLayout>
</ScrollView>

