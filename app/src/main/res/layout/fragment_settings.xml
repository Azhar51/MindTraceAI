<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Permissions"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_settings_permission_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Usage access is not granted yet"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_settings_manage_permission"
                    style="@style/MindTracePrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Manage Usage Access" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tracking controls"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_settings_tracking_enabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:checked="true"
                    android:text="Enable MindTrace tracking"
                    android:textColor="@color/text_main" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_settings_include_system_apps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Include system apps in usage analytics"
                    android:textColor="@color/text_main" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_settings_background_snapshots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:checked="true"
                    android:text="Save daily background snapshots"
                    android:textColor="@color/text_main" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy and reminders"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_settings_privacy_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Privacy mode for calmer analytics views"
                    android:textColor="@color/text_main" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Notification timing"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rg_settings_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_settings_notifications_gentle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gentle reminders"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_settings_notifications_balanced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="Balanced reminders"
                        android:textColor="@color/text_main" />

                    <RadioButton
                        android:id="@+id/rb_settings_notifications_minimal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Minimal reminders"
                        android:textColor="@color/text_main" />
                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_settings_refresh_now"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Refresh Dashboard Now" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Data Export & Privacy -->
        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data &amp; Privacy"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export_data"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="📦 Export All Data (JSON)" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clinician_export"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="🩺 Export Clinician Report" />

                <TextView
                    android:id="@+id/tv_storage_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Loading storage stats..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_delete_all_data"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="🗑️ Delete All Data"
                    android:textColor="@color/crisis_alert" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notification Preferences -->
        <com.google.android.material.card.MaterialCardView
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_daily_reminders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:checked="true"
                    android:text="Daily check-in reminders"
                    android:textColor="@color/text_main" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_streak_alerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:checked="true"
                    android:text="Streak milestones"
                    android:textColor="@color/text_main" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_weekly_report"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:checked="true"
                    android:text="Weekly wellness report"
                    android:textColor="@color/text_main" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Developer Tools (debug builds only — hidden in release) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_debug_tools"
            style="@style/MindTraceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛠️ Developer Tools"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Inject mock trajectory data for UI testing"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_stable"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="✓  Inject Stable (7 days)" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_worsening"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="▲  Inject Worsening (7 days)" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_improving"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="▼  Inject Improving (7 days)" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_crisis"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="⚠  Inject Crisis Escalation (10 days)"
                    android:textColor="@color/crisis_alert" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_mixed"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="↕  Inject Mixed Recovery (14 days)" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_gradual"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="↗  Inject Gradual Worsening (7 days)" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/text_secondary"
                    android:alpha="0.2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_dump"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋  Dump Classifications to Log" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sim_clear"
                    style="@style/MindTraceOutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="🗑️  Clear All Classifications"
                    android:textColor="@color/crisis_alert" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
