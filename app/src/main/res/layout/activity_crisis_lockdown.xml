<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Pulsing heart -->
    <TextView
        android:id="@+id/tv_lockdown_heart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤍"
        android:textSize="72sp" />

    <!-- Main message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="You are not alone."
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_lockdown_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="What you're feeling right now is temporary.\nPlease reach out — someone is ready to listen."
        android:textColor="#CCFFFFFF"
        android:textSize="16sp" />

    <!-- Helpline — prominent -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_helpline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#1AF44336"
        app:cardCornerRadius="20dp"
        app:strokeColor="#33F44336"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="988 Suicide &amp; Crisis Lifeline"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_call_988"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="📞 Call 988 Now"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#F44336"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_text_741741"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="💬 Text HOME to 741741"
                android:textAllCaps="false"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                app:cornerRadius="14dp"
                app:strokeColor="#33FFFFFF"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Emergency contacts -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_emergency_contacts"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="📞 Call My Emergency Contact"
        android:textAllCaps="false"
        android:textColor="#CCFFFFFF"
        android:textSize="15sp"
        app:cornerRadius="14dp"
        app:strokeColor="#33FFFFFF"
        app:strokeWidth="1dp" />

    <!-- Breathing exercise (limited option) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_breathing"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="🌬️ Breathing Exercise"
        android:textAllCaps="false"
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        app:cornerRadius="14dp"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp" />

    <!-- Countdown + dismiss area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center">

        <!-- Circular countdown arc (fills over 60 seconds) -->
        <com.mindtrace.ai.ui.components.CircularCountdownView
            android:id="@+id/countdown_arc"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center" />

        <!-- Timer text + dismiss button centered over the arc -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_dismiss_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please stay for 60 seconds"
                android:textColor="#66FFFFFF"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dismiss"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:enabled="false"
                android:text="I'm feeling safer now"
                android:textAllCaps="false"
                android:textColor="#33FFFFFF"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
