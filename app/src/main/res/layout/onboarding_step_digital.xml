<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱  Social pull" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="This helps shape your distraction risk score." />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Social media use" />
                    <TextView android:id="@+id/tv_social_media_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <!-- Live descriptor label -->
                <TextView android:id="@+id/tv_social_media_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Moderate — you check often but can stop" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_social_media_use" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Late-night phone use" />
                    <TextView android:id="@+id/tv_late_night_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView android:id="@+id/tv_late_night_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Sometimes — a few nights per week" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_late_night_use" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🪝  Addiction risk" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="How addictive does it feel?" />
                    <TextView android:id="@+id/tv_addiction_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView android:id="@+id/tv_addiction_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Moderate — you notice the pull but manage it" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_app_addiction_risk" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Overuse pattern" />
                    <TextView android:id="@+id/tv_overuse_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <com.google.android.material.slider.Slider android:id="@+id/slider_overuse_pattern" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔁  Scrolling pattern" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Binge scrolling" />
                    <TextView android:id="@+id/tv_binge_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = rare · 5 = frequent" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_binge_scrolling" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Random app switching" />
                    <TextView android:id="@+id/tv_switching_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <com.google.android.material.slider.Slider android:id="@+id/slider_app_switching" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- NEW: Trigger Apps + Screen Awareness Card -->
        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📌  Your trigger apps" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Which apps pull you in the most? Select all that apply." />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_trigger_apps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="6dp">
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Instagram" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TikTok" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="YouTube" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Twitter/X" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Snapchat" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reddit" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Games" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WhatsApp" />
                </com.google.android.material.chip.ChipGroup>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Screen time awareness" />
                    <TextView android:id="@+id/tv_screen_awareness_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" />
                </LinearLayout>
                <TextView android:id="@+id/tv_screen_awareness_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Aware — you know it affects you" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_screen_awareness" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="10" android:stepSize="1" android:value="5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- NEW: Real-time Digital Risk Preview -->
        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1E2E">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="⚡ Your digital risk preview" />
                    <TextView android:id="@+id/tv_digital_risk_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_overview_list_dot" android:paddingStart="12dp" android:paddingTop="4dp" android:paddingEnd="12dp" android:paddingBottom="4dp" android:text="Moderate" android:textColor="@color/text_main" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_digital_risk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="50"
                    app:indicatorColor="@color/risk_moderate"
                    app:trackColor="@color/outline"
                    app:trackCornerRadius="8dp"
                    app:trackThickness="8dp" />
                <TextView android:id="@+id/tv_digital_risk_summary" style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Based on your answers, your digital dependency is moderate. MindTrace will calibrate interventions to help." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- NEW: Peak Vulnerability Time -->
        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🕐  When are you most vulnerable?" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="When do you tend to lose control of screen time the most?" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_vulnerability_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌅 Morning" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☀️ Afternoon" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌆 Evening" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌙 Late night" android:checked="true" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔀 Unpredictable" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
