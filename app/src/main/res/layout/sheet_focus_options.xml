<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_surface"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Focus Mode"
        android:textColor="@color/text_main"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:text="Select how you want to manage your attention today."
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pomodoro_timer"
        style="@style/MindTracePrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:text="Pomodoro Timer"
        app:icon="@drawable/ic_mission_focus"
        app:iconGravity="textStart"
        app:iconPadding="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_app_blocker_settings"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="App Blocker Settings"
        android:textColor="@color/text_main"
        app:strokeColor="@color/text_secondary"
        app:icon="@android:drawable/ic_secure"
        app:iconTint="@color/text_main"
        app:iconGravity="textStart"
        app:iconPadding="12dp" />

</LinearLayout>
