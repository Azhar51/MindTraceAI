<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    android:gravity="top|start">

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_circle_primary"
        android:padding="6dp"
        android:src="@drawable/ic_sparkle"
        app:tint="@color/white" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="48dp">

        <TextView
            android:id="@+id/tv_coach_message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_bubble_ai"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:text="Hi Alex. I noticed your screen time is elevated today."
            android:textColor="@color/text_main"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <!-- Container for interactive widgets (e.g., action buttons injected by AI) -->
        <FrameLayout
            android:id="@+id/container_coach_widget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
