<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Timeline header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/timeline_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_chip_selected" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_event_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crisis Event"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_event_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today, 3:42 PM"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Distress badge -->
        <TextView
            android:id="@+id/tv_distress_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_selected"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="7 → 3"
            android:textColor="@color/text_main"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Event details card -->
    <com.google.android.material.card.MaterialCardView
        style="@style/MindTraceCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Resolution method -->
            <TextView
                android:id="@+id/tv_resolution_method"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Resolved via breathing exercise"
                android:textColor="@color/calm_green"
                android:textSize="13sp" />

            <!-- Active signals -->
            <TextView
                android:id="@+id/tv_signals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Signals: elevated questionnaire, journal keywords"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />

            <!-- Duration -->
            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Duration: 8 min"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Timeline line (connector to next event) -->
    <View
        android:id="@+id/timeline_connector"
        android:layout_width="2dp"
        android:layout_height="20dp"
        android:layout_marginStart="6dp"
        android:background="@color/outline" />
</LinearLayout>
