<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_behavior_sheet_surface"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="14dp"
        android:paddingEnd="22dp"
        android:paddingBottom="32dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="44dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_overview_drag_handle" />

        <!-- Header Row: Title + Status Chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_behavior_sheet_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Behavior Breakdown"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.mindtrace.ai.ui.components.StateChipView
                android:id="@+id/chip_behavior_sheet_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Watch" />
        </LinearLayout>

        <!-- Subtitle description -->
        <TextView
            android:id="@+id/tv_behavior_sheet_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:text="Repetitive loop behavior"
            android:textColor="#9CA3AF"
            android:textSize="14sp" />

        <!-- Explanation body -->
        <TextView
            android:id="@+id/tv_behavior_sheet_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="3dp"
            android:textColor="#7B8694"
            android:textSize="13sp" />

        <!-- ═══ Signal Cards Section ═══ -->
        <LinearLayout
            android:id="@+id/layout_behavior_signal_cards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical" />

        <!-- ═══ Loop Visualization Section ═══ -->
        <LinearLayout
            android:id="@+id/layout_behavior_loop_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_behavior_sheet_loop_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="Loop Pattern"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_behavior_loop_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_behavior_sheet_status_pill"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="Detected"
                    android:textColor="#F59E0B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_behavior_loop_icons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_behavior_loop_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#7B8694"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ═══ Quick Stats Row ═══ -->
        <LinearLayout
            android:id="@+id/layout_behavior_stats_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Active/Passive Stat -->
            <LinearLayout
                android:id="@+id/layout_behavior_stat_ratio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_behavior_sheet_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_behavior_stat_ratio_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="--"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Active/Passive"
                    android:textColor="#7B8694"
                    android:textSize="11sp" />
            </LinearLayout>

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <!-- Switches Stat -->
            <LinearLayout
                android:id="@+id/layout_behavior_stat_switches"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_behavior_sheet_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔀"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_behavior_stat_switches_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="--"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="App Switches"
                    android:textColor="#7B8694"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Primary Action Button ═══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_behavior_sheet_action"
            style="@style/MindTracePrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="View screen time details" />

    </LinearLayout>
</ScrollView>
