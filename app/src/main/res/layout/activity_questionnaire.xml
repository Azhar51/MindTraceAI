<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_onboarding_gradient">

    <!-- ── Compact header ── -->
    <LinearLayout
        android:id="@+id/layout_onboarding_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MindTrace"
                android:textColor="@color/onboarding_brand"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_onboarding_step_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_onboarding_step_badge"
                android:paddingStart="10dp"
                android:paddingTop="3dp"
                android:paddingEnd="10dp"
                android:paddingBottom="3dp"
                style="@style/Onboarding.Text.StepBadge" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_onboarding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:indicatorColor="@color/onboarding_progress_fill"
            app:trackColor="@color/onboarding_progress_bg"
            app:trackCornerRadius="3dp"
            app:trackThickness="4dp" />

        <TextView
            android:id="@+id/tv_onboarding_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            style="@style/Onboarding.Text.Title" />

        <TextView
            android:id="@+id/tv_onboarding_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            style="@style/Onboarding.Text.Subtitle" />
    </LinearLayout>

    <!-- ── Content area ── -->
    <ViewFlipper
        android:id="@+id/view_flipper_onboarding"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toTopOf="@id/layout_onboarding_footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_onboarding_header">

        <include layout="@layout/onboarding_step_identity" />
        <include layout="@layout/onboarding_step_emotional" />
        <include layout="@layout/onboarding_step_functioning" />
        <include layout="@layout/onboarding_step_digital" />
        <include layout="@layout/onboarding_step_lifestyle" />
        <include layout="@layout/onboarding_step_support" />
        <include layout="@layout/onboarding_step_nutrition" />
        <include layout="@layout/onboarding_step_complete" />
    </ViewFlipper>

    <!-- ── Footer ── -->
    <LinearLayout
        android:id="@+id/layout_onboarding_footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/onboarding_footer_bg"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:background="@color/onboarding_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_onboarding_back"
                style="@style/Onboarding.Button.Back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:visibility="gone" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_onboarding_next"
                style="@style/Onboarding.Button.Next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="180dp"
                android:text="Continue" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
