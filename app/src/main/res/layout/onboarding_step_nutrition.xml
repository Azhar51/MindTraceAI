<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingBottom="16dp">

        <!-- ═════════════════════════════════════════════ -->
        <!-- Card 1: Hydration & Caffeine                 -->
        <!-- ═════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💧  Hydration &amp; Stimulants" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="What you drink directly affects focus, anxiety, and sleep quality." />

                <!-- Water intake -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Daily water intake" />
                    <TextView android:id="@+id/tv_water_intake_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = barely any · 3 = moderate · 5 = well hydrated" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_water_intake" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
                <TextView android:id="@+id/tv_water_intake_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/onboarding_body" />

                <!-- Caffeine intake -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Caffeine consumption" />
                    <TextView android:id="@+id/tv_caffeine_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = none · 3 = moderate (2-3 cups) · 5 = heavy (5+ cups)" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_caffeine_intake" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
                <TextView android:id="@+id/tv_caffeine_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/onboarding_body" />

                <!-- Alcohol use -->
                <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="Alcohol frequency" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_alcohol"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Never" android:checked="true" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rarely" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Daily" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═════════════════════════════════════════════ -->
        <!-- Card 2: Diet Quality & Patterns              -->
        <!-- ═════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥗  Diet &amp; Nutrition" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Your gut-brain connection is real — diet shapes mood, energy, and cognition." />

                <!-- Diet quality -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Overall diet quality" />
                    <TextView android:id="@+id/tv_diet_quality_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = mostly processed · 3 = mixed · 5 = balanced whole foods" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_diet_quality" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
                <TextView android:id="@+id/tv_diet_quality_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/onboarding_body" />

                <!-- Meal regularity -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Meal regularity" />
                    <TextView android:id="@+id/tv_meal_regularity_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = skip meals often · 3 = somewhat regular · 5 = consistent meals" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_meal_regularity" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />

                <!-- Sugar intake -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sugar / junk food intake" />
                    <TextView android:id="@+id/tv_sugar_intake_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = minimal · 3 = moderate · 5 = daily high sugar" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_sugar_intake" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═════════════════════════════════════════════ -->
        <!-- Card 3: Eating Patterns & Emotional Eating   -->
        <!-- ═════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView style="@style/Onboarding.Card.Premium" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍽️  Eating Patterns" />

                <!-- Emotional eating -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Emotional / stress eating" />
                    <TextView android:id="@+id/tv_emotional_eating_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = never · 3 = sometimes when stressed · 5 = constant comfort eating" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_emotional_eating" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="2" />
                <TextView android:id="@+id/tv_emotional_eating_desc" style="@style/Onboarding.Text.SliderHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="@color/onboarding_body" />

                <!-- Late night eating -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView style="@style/Onboarding.Text.SliderLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Late-night eating" />
                    <TextView android:id="@+id/tv_late_eating_value" style="@style/Onboarding.Text.SliderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" />
                </LinearLayout>
                <TextView style="@style/Onboarding.Text.SliderHint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="1 = never eat late · 3 = sometimes · 5 = regularly eat after 10pm" />
                <com.google.android.material.slider.Slider android:id="@+id/slider_late_eating" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:valueFrom="1" android:valueTo="5" android:stepSize="1" android:value="2" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
