<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <!-- Name -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Onboarding.Card.Premium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="What should we call you?" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="A first name is enough — it makes things personal." />
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Onboarding.Input.Premium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Your name"
                    app:boxBackgroundMode="outline">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_onboarding_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName|textCapWords"
                        android:maxLines="1"
                        android:textColor="@color/onboarding_heading"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Age Range -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Onboarding.Card.Premium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Age range" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Helps calibrate guidance to your life stage." />
                <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_age" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:chipSpacingHorizontal="8dp" app:chipSpacingVertical="6dp" app:singleLine="false" app:singleSelection="true">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_age_13_15" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13 – 15" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_age_16_18" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:text="16 – 18" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_age_19_21" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="19 – 21" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_age_22_plus" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="22+" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Primary Goal -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Onboarding.Card.Premium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="What matters most right now?" />
                <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_goal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:chipSpacingHorizontal="8dp" app:chipSpacingVertical="6dp" app:singleLine="false" app:singleSelection="true">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_goal_focus" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:text="🎯  Study with focus" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_goal_routine" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧭  Build a routine" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_goal_control" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒  Feel more in control" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_goal_sleep" style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌙  Sleep better" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Help Areas -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Onboarding.Card.Premium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Onboarding.Text.CardTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Where do you want help?" />
                <TextView style="@style/Onboarding.Text.CardHelper" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Pick any that resonate. This shapes your first missions." />
                <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_help" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:chipSpacingHorizontal="8dp" app:chipSpacingVertical="6dp" app:singleLine="false">
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📵  Phone addiction" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡  Low motivation" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🗓  Poor routine" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😴  Sleep drift" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌀  Overthinking" />
                    <com.google.android.material.chip.Chip style="@style/Onboarding.Chip.Premium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧩  Feeling stuck" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
