<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MindTraceAI" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_main</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOnBackground">@color/text_main</item>
        <item name="android:textColorPrimary">@color/text_main</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@drawable/bg_app_background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <item name="materialCardViewStyle">@style/MindTraceCard</item>
        <item name="materialButtonStyle">@style/MindTracePrimaryButton</item>
        <item name="bottomNavigationStyle">@style/MindTraceBottomNavigation</item>
        <item name="toolbarStyle">@style/MindTraceToolbar</item>
    </style>

    <!-- Dark premium theme for the onboarding questionnaire -->
    <style name="Theme.MindTraceAI.Onboarding" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/onboarding_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/onboarding_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/onboarding_surface</item>
        <item name="colorOnSurface">@color/onboarding_heading</item>
        <item name="colorSurfaceVariant">@color/onboarding_surface_alt</item>
        <item name="colorOnSurfaceVariant">@color/onboarding_body</item>
        <item name="colorOnBackground">@color/onboarding_heading</item>
        <item name="android:windowBackground">@color/onboarding_bg</item>
        <item name="android:statusBarColor">@color/onboarding_bg</item>
        <item name="android:navigationBarColor">@color/onboarding_footer_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <item name="sliderStyle">@style/Widget.Material3.Slider</item>
    </style>
</resources>
