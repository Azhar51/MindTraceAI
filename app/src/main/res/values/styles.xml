<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MindTraceCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="MindTracePrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="iconTint">@color/white</item>
    </style>

    <style name="MindTraceOutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="rippleColor">@color/state_badge_bg</item>
    </style>

    <style name="MindTraceToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="titleTextColor">@color/text_main</item>
    </style>

    <style name="MindTraceBottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface</item>
        <item name="elevation">0dp</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Material3.BottomNavigationView.ActiveIndicator</item>
    </style>

    <!-- Legacy onboarding styles (kept for reference / other screens) -->
    <style name="MindTraceOnboardingCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/onboarding_surface</item>
        <item name="cardCornerRadius">26dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/onboarding_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="MindTraceOnboardingPrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">58dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/onboarding_primary</item>
        <item name="cornerRadius">22dp</item>
        <item name="iconTint">@color/white</item>
    </style>

    <style name="MindTraceOnboardingBackButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">54dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/onboarding_heading</item>
        <item name="cornerRadius">20dp</item>
        <item name="rippleColor">@color/onboarding_selected_bg</item>
    </style>

    <style name="MindTraceOnboardingChoiceChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/onboarding_choice_bg</item>
        <item name="chipStrokeColor">@color/onboarding_choice_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipMinHeight">52dp</item>
        <item name="chipCornerRadius">18dp</item>
        <item name="android:textColor">@color/onboarding_choice_text</item>
        <item name="android:textStyle">bold</item>
        <item name="checkedIconVisible">false</item>
        <item name="ensureMinTouchTargetSize">true</item>
    </style>

    <style name="MindTraceOnboardingInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/onboarding_surface</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxStrokeColor">@color/onboarding_outline</item>
        <item name="hintTextColor">@color/onboarding_body</item>
        <item name="android:textColorHint">@color/onboarding_body</item>
    </style>

    <!-- ======================================================= -->
    <!-- PREMIUM ONBOARDING v2 STYLES                            -->
    <!-- ======================================================= -->

    <style name="Onboarding.Card.Premium" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/onboarding_card_bg</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/onboarding_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Onboarding.Button.Next" parent="Widget.Material3.Button">
        <item name="android:minHeight">50dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="backgroundTint">@color/onboarding_accent</item>
        <item name="cornerRadius">16dp</item>
        <item name="iconTint">@color/white</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
    </style>

    <style name="Onboarding.Button.Back" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">50dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/onboarding_body</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">16dp</item>
        <item name="rippleColor">@color/onboarding_accent_soft</item>
    </style>

    <style name="Onboarding.Chip.Premium" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/onboarding_choice_bg</item>
        <item name="chipStrokeColor">@color/onboarding_choice_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipMinHeight">44dp</item>
        <item name="chipCornerRadius">14dp</item>
        <item name="android:textColor">@color/onboarding_choice_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="checkedIconVisible">false</item>
        <item name="ensureMinTouchTargetSize">true</item>
        <item name="chipStartPadding">14dp</item>
        <item name="chipEndPadding">14dp</item>
    </style>

    <!-- Alias for non-premium contexts that still need the same chip look -->
    <style name="Onboarding.Chip" parent="Onboarding.Chip.Premium" />

    <style name="Onboarding.Input.Premium" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/onboarding_surface</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/onboarding_outline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="hintTextColor">@color/onboarding_accent</item>
        <item name="android:textColorHint">@color/onboarding_body</item>
    </style>

    <style name="Onboarding.Toggle.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/onboarding_card_bg</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/onboarding_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Base styles for implicit parent chain resolution -->
    <style name="Onboarding" parent="" />

    <style name="Onboarding.Text" parent="">
        <item name="android:textColor">@color/onboarding_heading</item>
    </style>

    <!-- Text styles for the onboarding hierarchy -->
    <style name="Onboarding.Text.StepBadge">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/onboarding_step_label</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="Onboarding.Text.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/onboarding_heading</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Onboarding.Text.Subtitle">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/onboarding_body</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Onboarding.Text.CardTitle">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/onboarding_heading</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Onboarding.Text.CardHelper">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/onboarding_helper</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Onboarding.Text.SliderLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/onboarding_heading</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="Onboarding.Text.SliderHint">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/onboarding_helper</item>
    </style>

    <style name="Onboarding.Text.SliderValue">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/onboarding_accent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Dialog theme for sparkline detail popups -->
    <style name="Theme_MindTraceDialog" parent="Theme.Material3.Dark.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/text_main</item>
        <item name="android:textColorPrimary">@color/text_main</item>
        <item name="buttonBarPositiveButtonStyle">@style/MindTraceDialogButton</item>
    </style>

    <style name="MindTraceDialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
