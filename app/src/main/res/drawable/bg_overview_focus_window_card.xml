<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:endColor="#991E293B"
                android:startColor="#CC0F766E"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#33F8FAFC" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <gradient
                android:angle="45"
                android:endColor="#260F172A"
                android:startColor="#4022D3EE"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
