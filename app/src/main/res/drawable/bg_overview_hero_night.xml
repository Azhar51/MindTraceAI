<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="315"
                android:centerColor="#C83040A0"
                android:endColor="#B20A1220"
                android:startColor="#D84858A8"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#38FFFFFF" />
        </shape>
    </item>

    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#10FFFFFF" />
        </shape>
    </item>

    <!-- Deep indigo accent for night protection atmosphere -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="225"
                android:endColor="#004F46E5"
                android:startColor="#184F46E5"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
