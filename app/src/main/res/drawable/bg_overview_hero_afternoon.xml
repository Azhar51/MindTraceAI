<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="320"
                android:centerColor="#CC1875B0"
                android:endColor="#B50D1828"
                android:startColor="#DC3AA08A"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#18FFFFFF" />
        </shape>
    </item>

    <!-- Cool blue accent for afternoon energy -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="135"
                android:endColor="#0038BDF8"
                android:startColor="#1038BDF8"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
