<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="315"
                android:centerColor="#D85A7A50"
                android:endColor="#B80E1827"
                android:startColor="#E47CAA62"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#44FFFFFF" />
        </shape>
    </item>

    <!-- Inner glow layer -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#20FFFFFF" />
        </shape>
    </item>

    <!-- Warm sunlight accent -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="45"
                android:endColor="#00F8D87B"
                android:startColor="#14F8D87B"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
