<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="315"
                android:centerColor="#C41A2C47"
                android:endColor="#A60E1624"
                android:startColor="#D6223150" />
            <stroke
                android:width="1dp"
                android:color="#52FFFFFF" />
        </shape>
    </item>

    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#1FFFFFFF" />
        </shape>
    </item>

    <item
        android:bottom="14dp"
        android:left="16dp"
        android:right="16dp"
        android:top="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="0"
                android:endColor="#00FFFFFF"
                android:startColor="#12FFFFFF" />
        </shape>
    </item>
</layer-list>
